{
  "name": "ivy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "npm run dev --prefix web",
    "dev:api": "npm run start:dev --prefix api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "build": "npm run build --prefix web && npm run build --prefix api"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
